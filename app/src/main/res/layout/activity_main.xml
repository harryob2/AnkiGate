<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp"
        android:paddingTop="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AnkiGate"
            android:textSize="30sp"
            android:textColor="@color/textPrimary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Complete your Anki deck to unlock apps"
            android:textSize="14sp"
            android:textColor="@color/textTertiary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REPETITIO EST MATER STUDIORUM"
            android:textSize="12sp"
            android:textColor="@color/textTertiary"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:letterSpacing="0.08"
            android:layout_marginBottom="28dp" />

        <!-- Deck status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DECK STATUS"
                android:textSize="11sp"
                android:textColor="@color/textTertiary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvDeckStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Checking deck status..."
                android:textSize="15sp"
                android:textColor="@color/textPrimary"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- Blocked apps card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BLOCKED APPS"
                android:textSize="11sp"
                android:textColor="@color/textTertiary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvBlockedApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Blocked apps:"
                android:textSize="14sp"
                android:textColor="@color/textSecondary"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- Config buttons -->
        <Button
            android:id="@+id/btnSelectDecks"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_surface"
            android:text="Select Decks"
            android:textColor="@color/textPrimary"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"
            android:drawableEnd="@drawable/ic_chevron_right"
            android:paddingStart="20dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical|start"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnSelectApps"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_surface"
            android:text="Select Blocked Apps"
            android:textColor="@color/textPrimary"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"
            android:drawableEnd="@drawable/ic_chevron_right"
            android:paddingStart="20dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical|start"
            android:layout_marginBottom="24dp" />

        <!-- Toggle button -->
        <Button
            android:id="@+id/btnToggleService"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_btn_accent"
            android:text="Start Monitoring"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null" />

    </LinearLayout>

</ScrollView>
